# CodeCourt Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# =============================================================================
# LLM Provider API Keys (at least one required)
# =============================================================================

# OpenAI - Get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic - Get key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Ollama (local) - No key needed, just the host URL
OLLAMA_HOST=http://localhost:11434

# =============================================================================
# Model Configuration (optional - defaults shown)
# =============================================================================

# Models for debate system agents
DEFENDER_MODEL=gpt-4o
PROSECUTOR_MODEL=gpt-4o
JUDGE_MODEL=claude-3-5-sonnet-20241022
SECURITY_MODEL=claude-3-5-sonnet-20241022

# =============================================================================
# Server Configuration (optional)
# =============================================================================

API_HOST=0.0.0.0
API_PORT=8000

# =============================================================================
# Development Settings (optional)
# =============================================================================

LOG_LEVEL=INFO
DEBUG=false
